[sub_resource type="GDScript" id="GDScript_t4tkb"]
script/source = "extends Button

# Path to the scene you want to load
@export var scene_path: String = \"res://scenes/opening.tscn\"

func _ready():
	# Connect the button's pressed signal to our function
	pressed.connect(_on_button_pressed)

func _on_button_pressed():
	# Change to the specified scene
	get_tree().change_scene_to_file(scene_path)
"

