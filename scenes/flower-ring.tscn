[sub_resource type="GDScript" id="GDScript_p506u"]
script/source = "extends Node2D

@export var ring_radius: float = 200.0
@export var num_slots: int = 12
@export var snap_distance: float = 50.0

var snap_points: Array = []
var occupied_slots: Dictionary = {}

func _ready():
	generate_snap_points()

func generate_snap_points():
	for i in range(num_slots):
		var angle = (2 * PI / num_slots) * i
		var snap_position = Vector2(
			ring_radius * cos(angle),
			ring_radius * sin(angle)
		)
		
		# Create a visual marker (optional, for debugging)
		var marker = Sprite2D.new()
		marker.position = snap_position
		# You can add a small circle texture here
		add_child(marker)
		
		snap_points.append({
			\"position\": snap_position,
			\"rotation\": angle + PI/2,  # Face outward from center
			\"occupied\": false,
			\"index\": i
		})

func get_nearest_snap_point(world_position: Vector2):
	var local_pos = to_local(world_position)
	var nearest = null
	var min_distance = snap_distance
	
	for point in snap_points:
		if point.occupied:
			continue
			
		var distance = local_pos.distance_to(point.position)
		if distance < min_distance:
			min_distance = distance
			nearest = point
	
	return nearest

func occupy_slot(slot_index: int, flower):
	if slot_index >= 0 and slot_index < snap_points.size():
		snap_points[slot_index].occupied = true
		occupied_slots[slot_index] = flower

func free_slot(slot_index: int):
	if slot_index >= 0 and slot_index < snap_points.size():
		snap_points[slot_index].occupied = false
		occupied_slots.erase(slot_index)
"

